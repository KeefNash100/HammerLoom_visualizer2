        // Target boundary scaled down slightly to 200,000 for instant mobile computation
        const testInstance = new EESPMirrorSieveEngine(200000);
        const results = testInstance.runSimulation(0.45);
        
        console.log("METRIC LOGS:", JSON.stringify(results.telemetry, null, 2));
        console.log("DIAGNOSTIC VERDICT:", JSON.stringify(results.diagnostics, null, 2));
